"ruleId":"react-hooks/static-components","severity":2,"message":"Error: Cannot create components during render\n\nComponents created during render will reset their state each time they are created. Declare components outside of render.\n\n  206 |             <div className=\"fade-in\">\n  207 |               <div style={styles.usersHeader}>\n> 208 |                 <SectionHeader \n      |                  ^^^^^^^^^^^^^ This component is created during render\n  209 |                   title=\"Gestão de Equipe\" \n  210 |                   description=\"Adicione ou remova membros da sua unidade na empresa.\" \n  211 |                 />\n\n  53 |   };\n  54 |\n> 55 |   const SectionHeader = ({ title, description }) => (\n     |                         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 56 |     <div style={styles.sectionHeader}>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 57 |       <h3 style={styles.sectionTitle}>{title}</h3>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 58 |       <p style={styles.sectionDesc}>{description}</p>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 59 |     </div>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 60 |   );\n     | ^^^^ The component is created during render here\n  61 |\n  62 |   return (\n  63 |     <div className=\"fade-in\">","line":208,"column":18,"endLine":208,"endColumn":31},{"ruleId":"react-hooks/static-components","severity":2,"message":"Error: Cannot create components during render\n\nComponents created during render will reset their state each time they are created. Declare components outside of render.\n\n  252 |           {activeTab === 'profile' && (\n  253 |             <div className=\"fade-in\">\n> 254 |               <SectionHeader \n      |                ^^^^^^^^^^^^^ This component is created during render\n  255 |                 title=\"Meu Perfil\" \n  256 |                 description=\"Suas informações pessoais de acesso ao sistema.\" \n  257 |               />\n\n  53 |   };\n  54 |\n> 55 |   const SectionHeader = ({ title, description }) => (\n     |                         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 56 |     <div style={styles.sectionHeader}>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 57 |       <h3 style={styles.sectionTitle}>{title}</h3>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 58 |       <p style={styles.sectionDesc}>{description}</p>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 59 |     </div>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 60 |   );\n     | ^^^^ The component is created during render here\n  61 |\n  62 |   return (\n  63 |     <div className=\"fade-in\">","line":254,"column":16,"endLine":254,"endColumn":29},{"ruleId":"react-hooks/static-components","severity":2,"message":"Error: Cannot create components during render\n\nComponents created during render will reset their state each time they are created. Declare components outside of render.\n\n  275 |           {activeTab === 'billing' && (\n  276 |             <div className=\"fade-in\">\n> 277 |               <SectionHeader \n      |                ^^^^^^^^^^^^^ This component is created during render\n  278 |                 title=\"Plano e Faturamento\" \n  279 |                 description=\"Gerencie sua assinatura do SmartMaint e histórico de pagamentos.\" \n  280 |               />\n\n  53 |   };\n  54 |\n> 55 |   const SectionHeader = ({ title, description }) => (\n     |                         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 56 |     <div style={styles.sectionHeader}>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 57 |       <h3 style={styles.sectionTitle}>{title}</h3>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 58 |       <p style={styles.sectionDesc}>{description}</p>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 59 |     </div>\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 60 |   );\n     | ^^^^ The component is created during render here\n  61 |\n  62 |   return (\n  63 |     <div className=\"fade-in\">","line":277,"column":16,"endLine":277,"endColumn":29}],"suppressedMessages":[],"errorCount":11,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\nimport { \n  Building2, Users, UserCircle, Shield, \n  CreditCard, Bell, Save, Plus, Trash2, Edit2,\n  Mail, ShieldCheck, ExternalLink, X, FileText, CalendarDays, RefreshCw, CheckCircle2\n} from 'lucide-react';\nimport { useAuth, ROLES } from '../contexts/AuthContext';\nimport { useData } from '../contexts/DataContext';\n\nconst Settings = () => {\n  const { user, token, activeTenant, tenants, hasRole } = useAuth();\n  const { users, addUser, updateUser, deleteUser } = useData();\n  const [activeTab, setActiveTab] = useState(hasRole([ROLES.ROOT, ROLES.ADMIN]) ? 'company' : 'profile');\n  const [isUserModalOpen, setIsUserModalOpen] = useState(false);\n  const [editingUserId, setEditingUserId] = useState(null);\n  \n  // Dados do contrato do tenant ativo\n  const currentTenant = Array.isArray(tenants) ? tenants.find(t => t.id === activeTenant) : null;\n  \n  const [userFormData, setUserFormData] = useState({\n    name: '',\n    email: '',\n    role: 'USUARIO'\n  });\n\n  const tabs = [\n    { id: 'company', label: 'Empresa', icon: Building2, roles: [ROLES.ROOT, ROLES.BACKOFFICE, ROLES.ADMIN] },\n    { id: 'users', label: 'Equipe', icon: Users, roles: [ROLES.ROOT, ROLES.BACKOFFICE, ROLES.ADMIN] },\n    { id: 'profile', label: 'Meu Perfil', icon: UserCircle, roles: [ROLES.ROOT, ROLES.BACKOFFICE, ROLES.ADMIN, ROLES.MANAGER, ROLES.USER] },\n    { id: 'billing', label: 'Faturamento', icon: CreditCard, roles: [ROLES.ROOT] },\n  ];\n\n  const handleOpenAddUser = () => {\n    setEditingUserId(null);\n    setUserFormData({ name: '', email: '', role: 'USUARIO' });\n    setIsUserModalOpen(true);\n  };\n\n  const handleOpenEditUser = (u) => {\n    setEditingUserId(u.id);\n    setUserFormData({ ...u });\n    setIsUserModalOpen(true);\n  };\n\n  const handleUserSubmit = (e) => {\n    e.preventDefault();\n    if (editingUserId) {\n      updateUser(editingUserId, userFormData);\n    } else {\n      addUser(userFormData);\n    }\n    setIsUserModalOpen(false);\n  };\n\n  const SectionHeader = ({ title, description }) => (\n    <div style={styles.sectionHeader}>\n      <h3 style={styles.sectionTitle}>{title}</h3>\n      <p style={styles.sectionDesc}>{description}</p>\n    </div>\n  );\n\n  return (\n    <div className=\"fade-in\">\n      <header style={styles.header}>\n        <div>\n          <h1 style={styles.pageTitle}>Configurações</h1>\n          <p style={styles.pageSubtitle}>Gerencie os detalhes da sua conta e da sua empresa.</p>\n        </div>\n      </header>\n\n      <div style={styles.container}>\n        {/* Sidebar de Abas */}\n        <div className=\"premium-card\" style={styles.tabSidebar}>\n          {tabs.map((tab) => {\n            if (!hasRole(tab.roles)) return null;\n            const isActive = activeTab === tab.id;\n            return (\n              <button \n                key={tab.id}\n                onClick={() => setActiveTab(tab.id)}\n                style={{\n                  ...styles.tabBtn,\n                  background: isActive ? 'rgba(30, 58, 138, 0.05)' : 'transparent',\n                  color: isActive ? 'var(--primary)' : 'var(--text-muted)',\n                  border: 'none',\n                  cursor: 'pointer'\n                }}\n              >\n                <tab.icon size={20} />\n                <span style={{ fontWeight: isActive ? '600' : '400' }}>{tab.label}</span>\n              </button>\n            );\n          })}\n        </div>\n\n        {/* Conteúdo da Aba */}\n        <div className=\"premium-card\" style={styles.contentArea}>\n          {activeTab === 'company' && (\n            <div className=\"fade-in\">\n              <SectionHeader \n                title=\"Informações da Empresa\" \n                description=\"Dados básicos da sua organização e unidade fabril.\" \n              />\n              <div style={styles.formGrid}>\n                <div style={styles.inputGroup}>\n                  <label style={styles.label}>Nome Fantasia</label>\n                  <input type=\"text\" defaultValue={currentTenant?.name || user?.company} style={styles.input} />\n                </div>\n                <div style={styles.inputGroup}>\n                  <label style={styles.label}>CNPJ</label>\n                  <input type=\"text\" placeholder=\"00.000.000/0001-00\" style={styles.input} />\n                </div>\n              </div>\n              <button className=\"btn-primary\" style={{ marginTop: '24px' }}>\n                <Save size={18} />\n                Salvar Alterações\n              </button>\n\n              {/* Seção: Contrato de Prestação de Serviços */}\n              <div style={{ marginTop: '48px' }}>\n                <SectionHeader \n                  title=\"Contrato de Prestação de Serviços\" \n                  description=\"Detalhes da vigência, renovação e valores do seu contrato com o SmartMaint.\" \n                />\n\n                {currentTenant ? (\n                  <>\n                    {/* Status Card */}\n                    <div style={{\n                      display: 'flex', alignItems: 'center', gap: '16px',\n                      padding: '20px', borderRadius: '12px', marginBottom: '24px',\n                      background: currentTenant.status === 'Ativo' ? 'rgba(16, 185, 129, 0.06)' : 'rgba(239, 68, 68, 0.06)',\n                      border: `1px solid ${currentTenant.status === 'Ativo' ? 'rgba(16, 185, 129, 0.2)' : 'rgba(239, 68, 68, 0.2)'}`,\n                    }}>\n                      <CheckCircle2 size={22} color={currentTenant.status === 'Ativo' ? '#10b981' : '#ef4444'} />\n                      <div style={{ flex: 1 }}>\n                        <p style={{ fontWeight: '700', fontSize: '15px', color: 'var(--text-main)' }}>\n                          Contrato {currentTenant.status === 'Ativo' ? 'Ativo' : currentTenant.status}\n                        </p>\n                        <p style={{ fontSize: '13px', color: 'var(--text-muted)' }}>\n                          Plano: <strong>{currentTenant.plan_type || 'Pro'}</strong> • Valor mensal: <strong>R$ {parseFloat(currentTenant.valor_mensal || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</strong>\n                        </p>\n                      </div>\n                      {currentTenant.renovacao_auto ? (\n                        <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '6px 14px', borderRadius: '8px', background: 'rgba(59, 130, 246, 0.08)', border: '1px solid rgba(59, 130, 246, 0.15)' }}>\n                          <RefreshCw size={14} color=\"var(--primary)\" />\n                          <span style={{ fontSize: '12px', fontWeight: '700', color: 'var(--primary)' }}>Renovação Automática</span>\n                        </div>\n                      ) : (\n                        <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '6px 14px', borderRadius: '8px', background: '#fef3c7', border: '1px solid #fcd34d' }}>\n                          <span style={{ fontSize: '12px', fontWeight: '700', color: '#b45309' }}>Renovação Manual</span>\n                        </div>\n                      )}\n                    </div>\n\n                    {/* Datas do Contrato */}\n                    <div style={styles.formGrid}>\n                      <div style={styles.inputGroup}>\n                        <label style={styles.label}><CalendarDays size={14} style={{ marginRight: '6px', verticalAlign: 'middle' }} />Início do Contrato</label>\n                        <input type=\"date\" value={currentTenant.contrato_inicio ? currentTenant.contrato_inicio.split('T')[0] : ''} style={styles.input} disabled />\n                      </div>\n                      <div style={styles.inputGroup}>\n                        <label style={styles.label}><CalendarDays size={14} style={{ marginRight: '6px', verticalAlign: 'middle' }} />Término / Renovação</label>\n                        <input type=\"date\" value={currentTenant.contrato_fim ? currentTenant.contrato_fim.split('T')[0] : ''} style={styles.input} disabled />\n                      </div>\n                    </div>\n\n                    {/* Tempo restante */}\n                    {currentTenant.contrato_fim && (() => {\n                      const hoje = new Date();\n                      const fim = new Date(currentTenant.contrato_fim);\n                      const diffMs = fim - hoje;\n                      const diasRestantes = Math.ceil(diffMs / (1000 * 60 * 60 * 24));\n                      const isExpiring = diasRestantes <= 30;\n                      return (\n                        <div style={{\n                          marginTop: '16px', padding: '14px 20px', borderRadius: '10px',\n                          background: isExpiring ? 'rgba(245, 158, 11, 0.06)' : 'rgba(30, 58, 138, 0.04)',\n                          border: `1px solid ${isExpiring ? 'rgba(245, 158, 11, 0.2)' : 'rgba(30, 58, 138, 0.1)'}`,\n                          display: 'flex', alignItems: 'center', gap: '10px'\n                        }}>\n                          <FileText size={16} color={isExpiring ? '#f59e0b' : 'var(--primary)'} />\n                          <span style={{ fontSize: '13px', color: 'var(--text-main)' }}>\n                            {diasRestantes > 0 ? (\n                              <>Faltam <strong>{diasRestantes} dias</strong> para a {currentTenant.renovacao_auto ? 'renovação automática' : 'expiração'} do contrato.</>\n                            ) : (\n                              <><strong style={{ color: '#ef4444' }}>Contrato expirado</strong> há {Math.abs(diasRestantes)} dias.</>\n                            )}\n                          </span>\n                        </div>\n                      );\n                    })()}\n\n                    <p style={{ fontSize: '12px', color: 'var(--text-muted)', marginTop: '20px' }}>\n                      Para alterações contratuais (cancelamento, upgrade de plano ou mudança no tipo de renovação), entre em contato com o suporte SmartMaint.\n                    </p>\n                  </>\n                ) : (\n                  <p style={{ color: 'var(--text-muted)', fontSize: '14px' }}>Dados do contrato não disponíveis.</p>\n                )}\n              </div>\n            </div>\n          )}\n\n          {activeTab === 'users' && (\n            <div className=\"fade-in\">\n              <div style={styles.usersHeader}>\n                <SectionHeader \n                  title=\"Gestão de Equipe\" \n                  description=\"Adicione ou remova membros da sua unidade na empresa.\" \n                />\n                <button className=\"btn-primary\" onClick={handleOpenAddUser}>\n                  <Plus size={18} />\n                  Adicionar Membro\n                </button>\n              </div>\n\n              <div style={styles.userList}>\n                {users.map((u) => (\n                  <div key={u.id} style={styles.userItem}>\n                    <div style={styles.userAvatar}>\n                      <UserCircle size={24} color={u.id === user?.id ? 'var(--primary)' : 'var(--text-muted)'} />\n                    </div>\n                    <div style={{ flex: 1 }}>\n                      <p style={styles.userName}>{u.name} {u.id === user?.id && '(Você)'}</p>\n                      <p style={styles.userEmail}>{u.email}</p>\n                    </div>\n                    <div style={{\n                      ...styles.roleBadge,\n                      background: u.role === 'DONO' ? 'rgba(30, 58, 138, 0.1)' : '#f1f5f9',\n                      color: u.role === 'DONO' ? 'var(--primary)' : '#64748b'\n                    }}>\n                      <Shield size={12} />\n                      {u.role}\n                    </div>\n                    <div style={{ display: 'flex', gap: '8px' }}>\n                      <button style={styles.actionBtn} onClick={() => handleOpenEditUser(u)}>\n                        <Edit2 size={18} />\n                      </button>\n                      {u.id !== user?.id && (\n                        <button style={styles.deleteBtn} onClick={() => deleteUser(u.id)}>\n                          <Trash2 size={18} />\n                        </button>\n                      )}\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n          {activeTab === 'profile' && (\n            <div className=\"fade-in\">\n              <SectionHeader \n                title=\"Meu Perfil\" \n                description=\"Suas informações pessoais de acesso ao sistema.\" \n              />\n              <div style={styles.formGrid}>\n                <div style={styles.inputGroup}>\n                  <label style={styles.label}>Nome Completo</label>\n                  <input type=\"text\" defaultValue={user?.name} style={styles.input} />\n                </div>\n                <div style={styles.inputGroup}>\n                  <label style={styles.label}>E-mail</label>\n                  <input type=\"email\" defaultValue={user?.email} style={styles.input} disabled />\n                </div>\n              </div>\n              <button className=\"btn-primary\" style={{ marginTop: '24px' }}>\n                <Save size={18} />\n                Atualizar Perfil\n              </button>\n            </div>\n          )}\n\n          {activeTab === 'billing' && (\n            <div className=\"fade-in\">\n              <SectionHeader \n                title=\"Plano e Faturamento\" \n                description=\"Gerencie sua assinatura do SmartMaint e histórico de pagamentos.\" \n              />\n              <div style={styles.billingCard}>\n                <div style={styles.billingHeader}>\n                  <div>\n                    <h4 style={styles.planTitle}>Plano Enterprise Industrial</h4>\n                    <p style={styles.planDesc}>Ativos ilimitados • 15 usuários • Suporte 24/7</p>\n                  </div>\n                  <div style={styles.planStatus}>Ativo</div>\n                </div>\n                <button style={styles.billingBtn}>\n                  Ver Notas Fiscais\n                  <ExternalLink size={16} />\n                </button>\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n\n      {/* Modal de Novo/Editar Usuário */}\n      {isUserModalOpen && (\n        <div style={styles.modalOverlay}>\n          <div className=\"premium-card fade-in\" style={styles.modal}>\n            <div style={styles.modalHeader}>\n              <h3 style={styles.modalTitle}>{editingUserId ? 'Editar Membro' : 'Adicionar Membro'}</h3>\n              <button onClick={() => setIsUserModalOpen(false)} style={styles.closeBtn}>\n                <X size={20} />\n              </button>\n            </div>\n            <form onSubmit={handleUserSubmit}>\n              <div style={styles.formGrid}>\n                <div style={{...styles.inputGroup, gridColumn: 'span 2'}}>\n                  <label style={styles.label}>Nome Completo</label>\n                  <input \n                    required \n                    type=\"text\" \n                    style={styles.input} \n                    value={userFormData.name}\n                    onChange={(e) => setUserFormData({...userFormData, name: e.target.value})}\n                  />\n                </div>\n                <div style={styles.inputGroup}>\n                  <label style={styles.label}>E-mail Corporativo</label>\n                  <input \n                    required \n                    type=\"email\" \n                    style={styles.input} \n                    value={userFormData.email}\n                    onChange={(e) => setUserFormData({...userFormData, email: e.target.value})}\n                  />\n                </div>\n                <div style={styles.inputGroup}>\n                  <label style={styles.label}>Cargo / Permissão</label>\n                  <select \n                    style={styles.select}\n                    value={userFormData.role}\n                    onChange={(e) => setUserFormData({...userFormData, role: e.target.value})}\n                  >\n                    <option value=\"Administrador\">Administrador</option>\n                    <option value=\"Usuário\">Operador (Usuário)</option>\n                  </select>\n                </div>\n                {!editingUserId && (\n                  <div style={{...styles.inputGroup, gridColumn: 'span 2'}}>\n                    <label style={styles.label}>Senha de Acesso (Provisória)</label>\n                    <input \n                      type=\"password\" \n                      style={styles.input} \n                      placeholder=\"Ex: 123456\"\n                      value={userFormData.password || ''}\n                      onChange={(e) => setUserFormData({...userFormData, password: e.target.value})}\n                    />\n                  </div>\n                )}\n              </div>\n              <div style={styles.modalFooter}>\n                <button type=\"button\" onClick={() => setIsUserModalOpen(false)} style={styles.cancelBtn}>Cancelar</button>\n                <button type=\"submit\" className=\"btn-primary\">\n                  {editingUserId ? 'Salvar Alterações' : 'Convidar Membro'}\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n};\n\nconst styles = {\n  header: { marginBottom: '32px' },\n  pageTitle: { fontSize: '24px', fontWeight: '700', color: 'var(--text-main)', marginBottom: '4px' },\n  pageSubtitle: { fontSize: '14px', color: 'var(--text-muted)' },\n  container: {