{\n      ...formData,\n      equipment_id: Number(formData.equipment_id),\n      tempo_operacao: Number(formData.tempo_operacao)\n    };\n\n    if (editingId) {\n      updateFailure(editingId, data);\n    } else {\n      addFailure(data);\n    }\n    setIsModalOpen(false);\n  };\n\n  return (\n    <div className=\"fade-in\">\n      <header style={styles.header}>\n        <div>\n          <h1 style={styles.pageTitle}>Eventos de Manutenção</h1>\n          <p style={styles.pageSubtitle}>Histórico completo de falhas e reparos realizados.</p>\n        </div>\n        <div style={styles.tabGroup}>\n          <button \n            style={{...styles.tab, borderBottom: activeTab === 'failures' ? '2px solid var(--primary)' : 'none'}}\n            onClick={() => setActiveTab('failures')}\n          >\n            <AlertTriangle size={18} color={activeTab === 'failures' ? 'var(--primary)' : 'var(--text-muted)'} />\n            <span style={{color: activeTab === 'failures' ? 'var(--primary)' : 'var(--text-muted)'}}>Falhas</span>\n          </button>\n          <button \n            style={{...styles.tab, borderBottom: activeTab === 'repairs' ? '2px solid var(--primary)' : 'none'}}\n            onClick={() => setActiveTab('repairs')}\n          >\n            <Wrench size={18} color={activeTab === 'repairs' ? 'var(--primary)' : 'var(--text-muted)'} />\n            <span style={{color: activeTab === 'repairs' ? 'var(--primary)' : 'var(--text-muted)'}}>Reparos</span>\n          </button>\n        </div>\n      </header>\n\n      {/* Toolbar */}\n      <div className=\"premium-card\" style={styles.toolbar}>\n        <div style={styles.searchWrapper}>\n          <Search size={18} color=\"var(--text-muted)\" />\n          <input type=\"text\" placeholder=\"Filtrar por equipamento ou descrição...\" style={styles.searchInput} />\n        </div>\n        <button className=\"btn-primary\" onClick={handleOpenAdd}>\n          <Plus size={18} />\n          Registrar {activeTab === 'failures' ? 'Falha' : 'Reparo'}\n        </button>\n      </div>\n\n      {/* Listagem */}\n      <div style={styles.listContainer}>\n        {activeTab === 'failures' ? (\n          failures.map((failure) => (\n            <div key={failure.id} className=\"premium-card\" style={styles.eventCard}>\n              <div style={{...styles.eventIcon, overflow: 'hidden'}}>\n                <img \n                  src={getEquipmentImage(failure.equipment_id)} \n                  alt=\"Equipamento\"\n                  style={{ width: '100%', height: '100%', objectFit: 'cover' }}\n                />\n              </div>\n              <div style={styles.eventInfo}>\n                <div style={styles.eventHeader}>\n                  <h3 style={styles.eventTitle}>{getEquipmentName(failure.equipment_id)}</h3>\n                  <span style={styles.eventDate}>{new Date(failure.data_falha).toLocaleDateString('pt-BR')}</span>\n                </div>\n                <p style={styles.eventDesc}>{failure.descricao}</p>\n                <div style={styles.eventMeta}>\n                  <Clock size={14} />\n                  <span>Operou por {failure.tempo_operacao}h até a falha</span>\n                </div>\n              </div>\n              <div style={styles.eventAction}>\n                <button style={styles.actionBtn} onClick={() => handleOpenEdit(failure)}>\n                  <Edit2 size={18} />\n                </button>\n                <button style={styles.deleteBtn} onClick={() => deleteFailure(failure.id)}>\n                  <Trash2 size={18} />\n                </button>\n              </div>\n            </div>\n          ))\n        ) : (\n          repairs.map((repair) => (\n            <div key={repair.id} className=\"premium-card\" style={styles.eventCard}>\n              <div style={{...styles.eventIcon, background: 'rgba(22, 163, 74, 0.1)'}}>\n                <CheckCircle2 size={20} color=\"var(--success)\" />\n              </div>\n              <div style={styles.eventInfo}>\n                <div style={styles.eventHeader}>\n                  <h3 style={styles.eventTitle}>{getEquipmentName(repair.equipment_id)}</h3>\n                  <span style={styles.eventDate}>{new Date(repair.data_reparo).toLocaleDateString('pt-BR')}</span>\n                </div>\n                <p style={styles.eventDesc}>Manutenção {repair.tipo} concluída com sucesso.</p>\n                <div style={styles.eventMeta}>\n                  <Clock size={14} />\n                  <span>Duração do Reparo: {repair.tempo_reparo}h</span>\n                </div>\n              </div>\n            </div>\n          ))\n        )}\n      </div>\n\n      {/* Modal de Registro */}\n      {isModalOpen && (\n        <div style={styles.modalOverlay}>\n          <div className=\"premium-card fade-in\" style={styles.modal}>\n            <div style={styles.modalHeader}>\n              <h3 style={styles.modalTitle}>{editingId ? 'Editar Ocorrência' : 'Registrar Ocorrência'}</h3>\n              <button onClick={() => setIsModalOpen(false)} style={styles.closeBtn}>\n                <X size={20} />\n              </button>\n            </div>\n            <form onSubmit={handleSubmit}>\n              <div style={styles.formGrid}>\n                <div style={styles.inputGroup}>\n                  <label style={styles.label}>Ativo Afetado</label>\n                  <select \n                    style={styles.select}\n                    value={formData.equipment_id}\n                    onChange={(e) => setFormData({...formData, equipment_id: e.target.value})}\n                  >\n                    {equipments.map(eq => (\n                      <option key={eq.id} value={eq.id}>{eq.name}</option>\n                    ))}\n                  </select>\n                </div>\n                <div style={styles.inputGroup}>\n                  <label style={styles.label}>Tempo de Operação (desde último reparo)</label>\n                  <input \n                    required\n                    type=\"number\" \n                    style={styles.input} \n                    placeholder=\"Ex: 450\"\n                    value={formData.tempo_operacao}\n                    onChange={(e) => setFormData({...formData, tempo_operacao: e.target.value})}\n                  />\n                </div>\n                <div style={{...styles.inputGroup, gridColumn: 'span 2'}}>\n                  <label style={styles.label}>Descrição da Falha</label>\n                  <textarea \n                    required\n                    style={{...styles.input, height: '80px', resize: 'none'}} \n                    placeholder=\"Descreva o que ocorreu...\"\n                    value={formData.descricao}\n                    onChange={(e) => setFormData({...formData, descricao: e.target.value})}\n                  />\n                </div>\n              </div>\n              <div style={styles.modalFooter}>\n                <button type=\"button\" onClick={() => setIsModalOpen(false)} style={styles.cancelBtn}>Cancelar</button>\n                <button type=\"submit\" className=\"btn-primary\">\n                  {editingId ? 'Salvar Alterações' : 'Registrar Evento'}\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n};\n\nconst Plus = ({ size }) => <Wrench size={size} />; // Fallback icon\n\nconst styles = {\n  header: {\n    display: 'flex',\n    justifyContent: 'space-between',\n    alignItems: 'flex-start',\n    marginBottom: '32px',\n  },\n  pageTitle: {\n    fontSize: '24px',\n    fontWeight: '700',\n    color: 'var(--text-main)',\n    marginBottom: '4px',\n  },\n  pageSubtitle: {\n    fontSize: '14px',\n    color: 'var(--text-muted)',\n  },\n  tabGroup: {\n    display: 'flex',\n    background: 'white',\n    padding: '4px',\n    borderRadius: '12px',\n    border: '1px solid var(--border)',\n  },\n  tab: {\n    display: 'flex',\n    alignItems: 'center',\n    gap: '8px',\n    padding: '8px 20px',\n    fontSize: '14px',\n    fontWeight: '600',\n    transition: 'var(--transition)',\n    background: 'transparent',\n    cursor: 'pointer',\n  },\n  toolbar: {\n    padding: '16px 24px',\n    display: 'flex',\n    justifyContent: 'space-between',\n    alignItems: 'center',\n    marginBottom: '24px',\n  },\n  searchWrapper: {\n    display: 'flex',\n    alignItems: 'center',\n    gap: '12px',\n    flex: 1,\n    maxWidth: '400px',\n  },\n  searchInput: {\n    width: '100%',\n    border: 'none',\n    fontSize: '14px',\n    color: 'var(--text-main)',\n  },\n  listContainer: {\n    display: 'flex',\n    flexDirection: 'column',\n    gap: '16px',\n  },\n  eventCard: {\n    padding: '20px',\n    display: 'flex',\n    alignItems: 'flex-start',\n    gap: '20px',\n  },\n  eventIcon: {\n    width: '44px',\n    height: '44px',\n    borderRadius: '12px',\n    display: 'flex',\n    alignItems: 'center',\n    justifyContent: 'center',\n    flexShrink: 0,\n  },\n  eventInfo: {\n    flex: 1,\n  },\n  eventHeader: {\n    display: 'flex',\n    justifyContent: 'space-between',\n    marginBottom: '4px',\n  },\n  eventTitle: {\n    fontSize: '16px',\n    fontWeight: '700',\n    color: 'var(--text-main)',\n  },\n  eventDate: {\n    fontSize: '12px',\n    color: 'var(--text-muted)',\n    fontWeight: '500',\n  },\n  eventDesc: {\n    fontSize: '14px',\n    color: 'var(--text-muted)',\n    marginBottom: '12px',\n  },\n  eventMeta: {\n    display: 'flex',\n    alignItems: 'center',\n    gap: '6px',\n    fontSize: '12px',\n    color: 'var(--primary)',\n    fontWeight: '600',\n  },\n  eventAction: {\n    display: 'flex',\n    alignItems: 'center',\n    gap: '8px',\n  },\n  actionBtn: {\n    color: 'var(--text-muted)',\n    padding: '8px',\n    borderRadius: '8px',\n    background: 'transparent',\n    cursor: 'pointer',\n  },\n  deleteBtn: {\n    color: '#94a3b8',\n    padding: '8px',\n    borderRadius: '8px',\n    background: 'transparent',\n    cursor: 'pointer',\n  },\n  modalOverlay: {\n    position: 'fixed',\n    top: 0,\n    left: 0,\n    right: 0,\n    bottom: 0,\n    background: 'rgba(0,0,0,0.4)',\n    display: 'flex',\n    alignItems: 'center',\n    justifyContent: 'center',\n    zIndex: 1000,\n    padding: '20px',\n  },\n  modal: {\n    width: '100%',\n    maxWidth: '600px',\n    padding: '32px',\n    background: 'white',\n  },\n  modalHeader: {\n    display: 'flex',\n    justifyContent: 'space-between',\n    alignItems: 'center',\n    marginBottom: '24px',\n  },\n  modalTitle: {\n    fontSize: '20px',\n    fontWeight: '700',\n    color: 'var(--text-main)',\n  },\n  closeBtn: {\n    color: 'var(--text-muted)',\n    background: 'transparent',\n  },\n  formGrid: {\n    display: 'grid',\n    gridTemplateColumns: '1fr 1fr',\n    gap: '20px',\n    marginBottom: '32px',\n  },\n  inputGroup: {\n    display: 'flex',\n    flexDirection: 'column',\n    gap: '8px',\n  },\n  label: {\n    fontSize: '13px',\n    fontWeight: '600',\n    color: 'var(--text-main)',\n  },\n  input: {\n    padding: '10px 14px',\n    borderRadius: '8px',\n    border: '1px solid var(--border)',\n    fontSize: '14px',\n  },\n  select: {\n    padding: '10px 14px',\n    borderRadius: '8px',\n    border: '1px solid var(--border)',\n    fontSize: '14px',\n    background: 'white',\n  },\n  modalFooter: {\n    display: 'flex',\n    justifyContent: 'flex-end',\n    gap: '12px',\n    borderTop: '1px solid var(--border)',\n    paddingTop: '20px',\n  },\n  cancelBtn: {\n    padding: '10px 20px',\n    borderRadius: '8px',\n    fontSize: '14px',\n    fontWeight: '600',\n    color: 'var(--text-muted)',\n    background: 'transparent',\n  }\n};\n\nexport default Failures;\n","usedDeprecatedRules":[]},{"filePath":"/home/frederico/react-project/smartmaint/src/pages/Login.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'React' is defined but never used.","line":1,"column":8,"messageId":"unusedVar","endLine":1,"endColumn":13,"suggestions":[{"messageId":"